{
  "name": "accordserver-mcp-client",
  "version": "0.2.0",
  "description": "MCP client for Accord chat — server admin and daccord desktop client control",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "accord-mcp": "dist/index.js",
    "daccord-mcp": "dist/client-cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:client": "node dist/client-cli.js",
    "dev": "tsx src/index.ts",
    "dev:client": "tsx src/client-cli.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
